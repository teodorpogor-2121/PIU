<Window x:Class="EssenceFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EssenceFlow – Adaugă Parfum"
        Height="620" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F7F3EF">

    <Window.Resources>
        <SolidColorBrush x:Key="CuloareAccent"      Color="#8B4513"/>
        <SolidColorBrush x:Key="CuloareEroare"      Color="#C0392B"/>
        <SolidColorBrush x:Key="CuloareLabel"       Color="#3E2723"/>
        <SolidColorBrush x:Key="CuloareBordura"     Color="#D7CCC8"/>
        <SolidColorBrush x:Key="CuloareBtnText"     Color="White"/>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource CuloareLabel}"/>
            <Setter Property="Padding"    Value="0,0,0,3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{StaticResource CuloareBordura}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Background"               Value="White"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StilEroare">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource CuloareEroare}"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush"              Value="{StaticResource CuloareBordura}"/>
            <Setter Property="Background"               Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="EssenceFlow"
                       FontFamily="Georgia"
                       FontSize="22"
                       FontStyle="Italic"
                       Foreground="{StaticResource CuloareAccent}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Adaugă Parfum Nou"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#795548"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
            <Rectangle Height="1" Fill="{StaticResource CuloareBordura}" Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <Label x:Name="LblId" Content="_ID Parfum"
                           Target="{Binding ElementName=TxtId}"/>
                    <TextBox x:Name="TxtId"/>
                    <TextBlock x:Name="ErrId"
                               Style="{StaticResource StilEroare}"
                               Text="ID-ul nu poate fi gol."/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <Label x:Name="LblNume" Content="_Nume Parfum"
                           Target="{Binding ElementName=TxtNume}"/>
                    <TextBox x:Name="TxtNume"/>
                    <TextBlock x:Name="ErrNume"
                               Style="{StaticResource StilEroare}"
                               Text="Numele nu poate fi gol și trebuie să aibă max. 50 de caractere."/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <Label x:Name="LblBrand" Content="_Brand"
                           Target="{Binding ElementName=TxtBrand}"/>
                    <TextBox x:Name="TxtBrand"/>
                    <TextBlock x:Name="ErrBrand"
                               Style="{StaticResource StilEroare}"
                               Text="Brandul nu poate fi gol și trebuie să aibă max. 30 de caractere."/>
                </StackPanel>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblConcentratie" Content="_Concentrație"/>
                        <ComboBox x:Name="CmbConcentratie">
                            <ComboBoxItem Content="EDP"    Tag="0"/>
                            <ComboBoxItem Content="EDT"    Tag="1"/>
                            <ComboBoxItem Content="EDC"    Tag="2"/>
                            <ComboBoxItem Content="Parfum" Tag="3"/>
                        </ComboBox>
                        <TextBlock x:Name="ErrConcentratie"
                                   Style="{StaticResource StilEroare}"
                                   Text="Selectați o concentrație."/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label x:Name="LblCantitate" Content="Cantitate (_ml)"
                               Target="{Binding ElementName=TxtCantitate}"/>
                        <TextBox x:Name="TxtCantitate"/>
                        <TextBlock x:Name="ErrCantitate"
                                   Style="{StaticResource StilEroare}"
                                   Text="Cantitate invalidă (1–1000 ml)."/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblStoc" Content="_Stoc (buc)"
                               Target="{Binding ElementName=TxtStoc}"/>
                        <TextBox x:Name="TxtStoc"/>
                        <TextBlock x:Name="ErrStoc"
                                   Style="{StaticResource StilEroare}"
                                   Text="Stoc invalid (0–9999)."/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label x:Name="LblPret" Content="_Preț (RON)"
                               Target="{Binding ElementName=TxtPret}"/>
                        <TextBox x:Name="TxtPret"/>
                        <TextBlock x:Name="ErrPret"
                                   Style="{StaticResource StilEroare}"
                                   Text="Preț invalid (0.01–99999 RON)."/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,10">
                    <Label x:Name="LblSezon" Content="_Sezon Recomandat"/>
                    <ComboBox x:Name="CmbSezon">
                        <ComboBoxItem Content="Primavara" Tag="Primavara"/>
                        <ComboBoxItem Content="Vara"      Tag="Vara"/>
                        <ComboBoxItem Content="Toamna"    Tag="Toamna"/>
                        <ComboBoxItem Content="Iarna"     Tag="Iarna"/>
                        <ComboBoxItem Content="Universal" Tag="Universal"/>
                    </ComboBox>
                    <TextBlock x:Name="ErrSezon"
                               Style="{StaticResource StilEroare}"
                               Text="Selectați un sezon."/>
                </StackPanel>

                <TextBlock x:Name="TxtMesajSucces"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnReset"
                    Grid.Column="0"
                    Content="_Reset"
                    Height="40"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="#EFEBE9"
                    Foreground="{StaticResource CuloareAccent}"
                    BorderBrush="{StaticResource CuloareAccent}"
                    BorderThickness="1"
                    Click="BtnReset_Click"/>

            <Button x:Name="BtnAdauga"
                    Grid.Column="2"
                    Content="_Adaugă"
                    Height="40"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="{StaticResource CuloareAccent}"
                    Foreground="{StaticResource CuloareBtnText}"
                    BorderThickness="0"
                    Click="BtnAdauga_Click"/>
        </Grid>

    </Grid>
</Window>